// Módulo 7 — Pagos y Agenda · Layer 12
// CSV Módulo 7 — Estado MVP: ✅ Incluido

// ─────────────────────────────────────────────────────
// Referencias externas
// ─────────────────────────────────────────────────────

Table app_user [note: 'Módulo 1 · Layer 4'] {
  user_id uuid [pk]
}

Table currency [note: 'Módulo 1 · Layer 1'] {
  currency_id bigint [pk]
}

Table status [note: 'Módulo 1 · Layer 1 — dominio: user_payment'] {
  status_id bigint [pk]
}

Table debt [note: 'Módulo 4 · Layer 11'] {
  debt_id uuid [pk]
}

Table financial_movement [note: 'Módulo 5 · Layer 9'] {
  movement_id uuid [pk]
}

// ─────────────────────────────────────────────────────
// Layer 12 — Pagos y Agenda
// ─────────────────────────────────────────────────────

Table user_payment {
  user_payment_id          uuid        [pk, default: `gen_random_uuid()`]
  user_id                  uuid        [not null, ref: > app_user.user_id]
  debt_id                  uuid        [null, ref: > debt.debt_id]
  movement_id              uuid        [null, ref: > financial_movement.movement_id]
  title                    varchar(200) [not null]
  amount                   decimal     [not null, note: '> 0']
  currency_id              bigint      [not null, ref: > currency.currency_id]
  due_date                 date        [not null]
  source                   varchar(10) [not null, default: 'user', note: "user | system"]
  traffic_light_state      varchar(10) [null, note: "green | yellow | red"]
  is_recurring             boolean     [not null, default: false]
  recurrence_interval_days int         [null]
  notes                    text        [null]
  user_payment_status_id   bigint      [not null, ref: > status.status_id, note: "Dominio: user_payment — pending | paid | overdue | cancelled"]
  paid_at                  timestamptz [null]
  cancelled_at             timestamptz [null]
  created_at               timestamptz [not null, default: `now()`]
  updated_at               timestamptz [not null, default: `now()`]

  indexes {
    (user_id, user_payment_status_id) [name: 'idx_up_user_status']
    (user_id, due_date) [name: 'idx_up_user_due', note: 'ASC']
  }
}

Table recurring_payment_suggestions {
  id                uuid        [pk, default: `gen_random_uuid()`]
  user_id           uuid        [not null, ref: > app_user.user_id]
  source            varchar(20) [not null, note: "movement_pattern | import"]
  suggested_payload jsonb       [not null, note: 'Ej: {"title":"Netflix","amount":17990,"day_of_month":15}']
  status            varchar(25) [not null, default: 'pending_user_confirm', note: "pending_user_confirm | accepted | dismissed"]
  created_at        timestamptz [not null, default: `now()`]
  updated_at        timestamptz [not null, default: `now()`]

  indexes {
    user_id [name: 'idx_rps_user_id']
  }
}
