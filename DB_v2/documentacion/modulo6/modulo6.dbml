// Módulo 6 — Presupuesto · Layer 10
// CSV Módulo 6 — Estado MVP: ✅ Incluido

// ─────────────────────────────────────────────────────
// Referencias externas
// ─────────────────────────────────────────────────────

Table app_user [note: 'Módulo 1 · Layer 4'] {
  user_id uuid [pk]
}

Table currency [note: 'Módulo 1 · Layer 1'] {
  currency_id bigint [pk]
}

Table category [note: 'Módulo 5 · Layer 7'] {
  category_id uuid [pk]
  is_leaf boolean
}

// ─────────────────────────────────────────────────────
// Layer 10 — Presupuesto
// ─────────────────────────────────────────────────────

Table budget_plan {
  budget_plan_id uuid    [pk, default: `gen_random_uuid()`]
  user_id        uuid    [not null, ref: > app_user.user_id]
  period_month   date    [not null, note: 'Primer día del mes. Ej: 2026-05-01']
  currency_id    bigint  [not null, ref: > currency.currency_id]
  created_at     timestamptz [not null, default: `now()`]
  updated_at     timestamptz [not null, default: `now()`]

  indexes {
    (user_id, period_month) [unique, name: 'uq_budget_plan_user_month']
    user_id [name: 'idx_bp_user']
  }
}

Table budget_plan_item {
  budget_plan_item_id uuid    [pk, default: `gen_random_uuid()`]
  budget_plan_id      uuid    [not null, ref: > budget_plan.budget_plan_id]
  category_id         uuid    [not null, ref: > category.category_id, note: 'Solo is_leaf = true']
  amount_limit        decimal [not null, note: '>= 0 — límite máximo de gasto']
  planned_min         decimal [null, note: 'Para presupuestos de ingresos variables']
  planned_max         decimal [null]
  suggested_by_app    boolean [not null, default: false]
  notes               text    [null]
  created_at          timestamptz [not null, default: `now()`]
  updated_at          timestamptz [not null, default: `now()`]

  indexes {
    (budget_plan_id, category_id) [unique, name: 'uq_budget_plan_item']
    budget_plan_id [name: 'idx_bpi_plan']
  }
}
