// Módulo 2 — B2B Corporativo (Layer 5)
// Estado MVP: ❌ Post-MVP — feature_b2b_enabled = false
// Dependencias entrantes: country (M1·L0), document_type (M1·L0), app_user (M1·L4)
// Dependencias salientes: subscription.company_id (M9), payment_method.company_id (M9)

// ─────────────────────────────────────────────────────
// Referencias externas (Módulo 1)
// ─────────────────────────────────────────────────────

Table country [note: 'Módulo 1 · Layer 0'] {
  country_id bigint [pk]
  iso2       char(2)
  name       varchar(100)
}

Table document_type [note: 'Módulo 1 · Layer 0'] {
  document_type_id bigint [pk]
  code             varchar(30)
  name             varchar(100)
}

Table app_user [note: 'Módulo 1 · Layer 4'] {
  user_id    uuid [pk]
  email      varchar(320)
}

// ─────────────────────────────────────────────────────
// Módulo 2 — Tablas propias
// ─────────────────────────────────────────────────────

Table company {
  company_id          uuid        [pk, default: `gen_random_uuid()`]
  name                varchar(200) [not null, note: 'Razón social']
  country_id          bigint      [not null, ref: > country.country_id]
  document_type_id    bigint      [null, ref: > document_type.document_type_id, note: 'Ej: RUT (CL), NIT (CO)']
  document_number     varchar(50) [null]
  contact_email       varchar(320) [null]
  contact_person_name varchar(150) [null]
  contact_phone       varchar(40)  [null]
  created_at          timestamptz [not null, default: `now()`]
  updated_at          timestamptz [not null, default: `now()`]

  indexes {
    (country_id, name)          [unique, name: 'uq_company_country_name']
    (country_id, document_number) [unique, name: 'uq_company_country_document']
  }
}

Table company_benefit_contract {
  contract_id uuid        [pk, default: `gen_random_uuid()`]
  company_id  uuid        [not null, ref: > company.company_id]
  plan_code   varchar(50) [not null, note: 'Código de convenio negociado. Ej: walvy_premium_12m']
  starts_at   date        [not null]
  ends_at     date        [null, note: 'NULL = vigencia indefinida']
  is_active   boolean     [not null, default: true]
  created_at  timestamptz [not null, default: `now()`]
  updated_at  timestamptz [not null, default: `now()`]

  indexes {
    (company_id) [name: 'idx_contract_company']
  }
}

Table company_eligible_employee {
  eligible_employee_id uuid        [pk, default: `gen_random_uuid()`]
  contract_id          uuid        [not null, ref: > company_benefit_contract.contract_id]
  email                varchar(320) [not null, note: 'Email del empleado para matching en registro']
  document_type_id     bigint      [null, ref: > document_type.document_type_id]
  document_number      varchar(50) [null]
  invited_at           timestamptz [null, note: 'Timestamp del último envío de invitación']
  activated_user_id    uuid        [null, ref: > app_user.user_id, note: 'Se llena cuando el empleado activa su cuenta']
  created_at           timestamptz [not null, default: `now()`]
  updated_at           timestamptz [not null, default: `now()`]

  indexes {
    (contract_id, email)                              [unique, name: 'uq_eligible_employee_contract_email']
    (contract_id, document_type_id, document_number)  [unique, name: 'uq_eligible_employee_contract_document', note: 'WHERE document_type_id IS NOT NULL AND document_number IS NOT NULL']
  }
}

Table benefit_invitation {
  invitation_id        uuid        [pk, default: `gen_random_uuid()`]
  eligible_employee_id uuid        [not null, ref: > company_eligible_employee.eligible_employee_id]
  invitation_status    varchar(20) [not null, note: "created | sent | accepted | expired | revoked"]
  sent_at              timestamptz [null, note: 'Requerido cuando status IN (sent, accepted)']
  accepted_at          timestamptz [null, note: 'Requerido cuando status = accepted']
  created_at           timestamptz [not null, default: `now()`]
  updated_at           timestamptz [not null, default: `now()`]

  indexes {
    (eligible_employee_id) [unique, name: 'uq_benefit_invitation_active', note: "WHERE invitation_status IN ('created','sent')"]
  }
}
