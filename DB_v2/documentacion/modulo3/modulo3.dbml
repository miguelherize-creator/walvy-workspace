// Módulo 3 — Home: Gamificación · Mensajería · Read Models CQRS (Layers 14, 15, 18, 19)
// CSV Módulo 3 — Estado MVP: ✅ Incluido
// Este módulo es principalmente de LECTURA — los read models son alimentados por jobs, no por el usuario

// ─────────────────────────────────────────────────────
// Referencias externas
// ─────────────────────────────────────────────────────

Table app_user [note: 'Módulo 1 · Layer 4'] {
  user_id uuid [pk]
}

Table admin_users [note: 'Módulo 8 · Layer 17'] {
  admin_user_id uuid [pk]
}

Table status [note: 'Módulo 1 · Layer 1 — dominio: message_event'] {
  status_id bigint [pk]
  code      varchar(50)
}

Table debt [note: 'Módulo 4'] {
  debt_id uuid [pk]
}

Table user_payment [note: 'Módulo 6'] {
  user_payment_id uuid [pk]
}

// ─────────────────────────────────────────────────────
// Layer 14 — Gamificación
// ─────────────────────────────────────────────────────

Table gamification_rules {
  id                  uuid        [pk, default: `gen_random_uuid()`]
  event_type          text        [not null, unique, note: 'Ej: debt_payment_registered, budget_met, onboarding_completed']
  points              int         [not null, default: 0]
  label               text        [not null]
  description         text        [null]
  is_active           boolean     [not null, default: true]
  updated_by_admin_id uuid        [null, ref: > admin_users.admin_user_id]
  created_at          timestamptz [not null, default: `now()`]
  updated_at          timestamptz [not null, default: `now()`]
}

Table gamification_events {
  id             uuid        [pk, default: `gen_random_uuid()`]
  user_id        uuid        [not null, ref: > app_user.user_id]
  event_type     text        [not null, note: 'Snapshot — no cambia si se edita la regla']
  points         int         [not null, note: 'Snapshot del valor en el momento del evento']
  reference_type text        [null, note: 'Entidad que disparó el evento. Ej: debt, budget_plan']
  reference_id   uuid        [null]
  created_at     timestamptz [not null, default: `now()`]

  indexes {
    (user_id, created_at) [name: 'idx_ge_user_created', note: 'DESC — logros recientes']
  }
}

Table user_gamification_stats {
  user_id          uuid        [pk, ref: - app_user.user_id, note: '1:1 con app_user']
  total_points     int         [not null, default: 0]
  level            int         [not null, default: 1]
  last_computed_at timestamptz [not null, default: `now()`]
}

Table user_score_history {
  id           uuid        [pk, default: `gen_random_uuid()`]
  user_id      uuid        [not null, ref: > app_user.user_id]
  period_start date        [not null]
  period_end   date        [not null]
  points       int         [not null]
  level        int         [not null]
  created_at   timestamptz [not null, default: `now()`]

  indexes {
    (user_id, period_start) [name: 'idx_ush_user_period', note: 'DESC']
  }
}

// ─────────────────────────────────────────────────────
// Layer 15 — Mensajería y Recomendaciones
// ─────────────────────────────────────────────────────

Table message_rule {
  message_rule_id uuid         [pk, default: `gen_random_uuid()`]
  code            varchar(80)  [not null, unique, note: 'Ej: leaks_detected, pay_next, budget_overrun']
  name_es         varchar(150) [not null]
  description_es  text         [null]
  context         varchar(20)  [null, note: "home | budget | debt | payments | profile | global"]
  deep_link       text         [null, note: 'Ruta de acción en la app']
  priority        smallint     [not null, default: 3, note: '1=urgente · 5=informativo']
  is_active       boolean      [not null, default: true]
  created_at      timestamptz  [not null, default: `now()`]
  updated_at      timestamptz  [not null, default: `now()`]
}

Table message_event {
  message_event_id        uuid        [pk, default: `gen_random_uuid()`]
  user_id                 uuid        [not null, ref: > app_user.user_id]
  message_rule_id         uuid        [not null, ref: > message_rule.message_rule_id]
  context_period_month    date        [null, note: 'Mes al que aplica si el mensaje es mensual']
  payload                 jsonb       [not null, note: 'Evidencia. Ej: {"overrun_pct": 120, "category": "Delivery"}']
  message_event_status_id bigint      [not null, ref: > status.status_id, note: "Dominio: message_event — created | shown | suppressed"]
  shown_at                timestamptz [null]
  suppressed_until        timestamptz [null, note: 'No mostrar hasta esta fecha (snoozed)']
  created_at              timestamptz [not null, default: `now()`]
  updated_at              timestamptz [not null, default: `now()`]

  indexes {
    (user_id, message_event_status_id, created_at) [name: 'idx_me_user_status']
  }
}

Table user_message_interaction {
  interaction_id   uuid        [pk, default: `gen_random_uuid()`]
  user_id          uuid        [not null, ref: > app_user.user_id]
  message_event_id uuid        [not null, ref: > message_event.message_event_id]
  action           varchar(20) [not null, note: "opened | dismissed | snoozed | completed"]
  action_at        timestamptz [not null, default: `now()`]
  note             text        [null]
  created_at       timestamptz [not null, default: `now()`]
  updated_at       timestamptz [not null, default: `now()`]

  indexes {
    (user_id, message_event_id) [name: 'idx_umi_user_event']
  }
}

// ─────────────────────────────────────────────────────
// Layer 18 — Read Models CQRS
// Actualizados por job periódico, no por el usuario
// ─────────────────────────────────────────────────────

Table user_month_diagnosis_summary {
  user_id                         uuid          [not null, ref: > app_user.user_id]
  month                           date          [not null, note: 'Primer día del mes']
  traffic_light_status            varchar(6)    [not null, note: "green | yellow | red"]
  traffic_light_reason_codes      text[]        [not null, note: 'Códigos que justifican el color']
  visible_savings_capacity_amount decimal       [not null, default: 0]
  visible_savings_capacity_pct    decimal       [null]
  uncategorized_movements_count   int           [not null, default: 0]
  data_quality_level              varchar(6)    [not null, note: "high | medium | low"]
  data_source_mix                 varchar(8)    [not null, note: "document | manual | both"]
  next_action_type                varchar(15)   [null, note: "pay | debt | budget | categorize | import"]
  next_action_ref_id              uuid          [null]
  rule_version                    varchar(50)   [not null]
  source_watermark_at             timestamptz   [not null]
  computed_at                     timestamptz   [not null, default: `now()`]
  created_at                      timestamptz   [not null, default: `now()`]
  updated_at                      timestamptz   [not null, default: `now()`]

  indexes {
    (user_id, month) [pk]
  }
}

Table user_month_debt_priority_summary {
  user_id                  uuid    [not null, ref: > app_user.user_id]
  month                    date    [not null]
  debt_id                  uuid    [not null, ref: > debt.debt_id]
  priority_rank            int     [not null, note: 'Orden Bola de Nieve (1 = mayor prioridad)']
  priority_score           decimal [not null]
  min_payment_amount       decimal [not null, default: 0]
  estimated_payoff_date    date    [null]
  released_cashflow_amount decimal [null, note: 'Liquidez liberada al cerrar esta deuda']
  rule_version             varchar(50) [not null]
  source_watermark_at      timestamptz [not null]
  computed_at              timestamptz [not null, default: `now()`]
  created_at               timestamptz [not null, default: `now()`]
  updated_at               timestamptz [not null, default: `now()`]

  indexes {
    (user_id, month, debt_id) [pk]
  }
}

Table user_upcoming_payments_summary {
  user_id                uuid    [not null, ref: > app_user.user_id]
  window_start           date    [not null]
  window_end             date    [not null]
  user_payment_id        uuid    [not null, ref: > user_payment.user_payment_id]
  due_date               date    [not null]
  amount                 decimal [not null]
  user_payment_status_id bigint  [not null, ref: > status.status_id]
  rule_version           varchar(50)   [not null]
  source_watermark_at    timestamptz   [not null]
  computed_at            timestamptz   [not null, default: `now()`]
  created_at             timestamptz   [not null, default: `now()`]
  updated_at             timestamptz   [not null, default: `now()`]

  indexes {
    (user_id, window_start, window_end, user_payment_id) [pk]
  }
}

Table user_month_leaks_summary {
  user_id             uuid    [not null, ref: > app_user.user_id]
  month               date    [not null]
  leaks_total_amount  decimal [not null, default: 0]
  leaks_count         int     [not null, default: 0]
  ant_expense_total   decimal [not null, default: 0, note: 'Gastos hormiga del mes']
  top_categories      jsonb   [null, note: 'Ej: [{"category":"Delivery","amount":45000}]']
  rule_version        varchar(50)   [not null]
  source_watermark_at timestamptz   [not null]
  computed_at         timestamptz   [not null, default: `now()`]
  created_at          timestamptz   [not null, default: `now()`]
  updated_at          timestamptz   [not null, default: `now()`]

  indexes {
    (user_id, month) [pk]
  }
}
